function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function showErr(id, msg) { const el = document.getElementById(id); el.textContent = msg; el.style.display = 'block'; }
function hideMsg(id) { const el = document.getElementById(id); if(el) el.style.display = 'none'; }

// ===================================================
//  AUTH FUNCTIONS
// ===================================================
function doSignup() {
  const name = document.getElementById('signupName').value.trim();
  const email = document.getElementById('signupEmail').value.trim().toLowerCase();
  const password = document.getElementById('signupPassword').value;
  hideMsg('signupError');
  if (!name || !email || !password) return showErr('signupError', 'All fields are required.');
  if (!email.includes('@')) return showErr('signupError', 'Enter a valid email.');
  if (password.length < 6) return showErr('signupError', 'Password must be at least 6 characters.');
  const users = getUsers();
  if (users[email]) return showErr('signupError', 'An account with this email already exists.');
  users[email] = { name, email, password, address: '', pic: '' };
  saveUsers(users);
  currentUser = users[email];
  saveCurrentUser(currentUser);
  closeModal('signupModal');
  updateHeader();
  renderAll();
}

function doLogin() {
  const email = document.getElementById('loginEmail').value.trim().toLowerCase();
  const password = document.getElementById('loginPassword').value;
  hideMsg('loginError');
  const users = getUsers();
  if (!users[email] || users[email].password !== password) return showErr('loginError', 'Invalid email or password.');
  currentUser = users[email];
  saveCurrentUser(currentUser);
  closeModal('loginModal');
  updateHeader();
  renderAll();
}

function doLogout() {
  currentUser = null;
  saveCurrentUser(null);
  updateHeader();
  currentSection = 'sec1';
  currentLevel = 0;
  renderAll();
}

function doForgotPassword() {
  const email = document.getElementById('forgotEmail').value.trim().toLowerCase();
  const newPass = document.getElementById('forgotNewPass').value;
  hideMsg('forgotError'); hideMsg('forgotSuccess');
  const users = getUsers();
  if (!users[email]) return showErr('forgotError', 'No account found with this email.');
  if (newPass.length < 6) return showErr('forgotError', 'New password must be at least 6 characters.');
  users[email].password = newPass;
  saveUsers(users);
  if (currentUser && currentUser.email === email) { currentUser.password = newPass; saveCurrentUser(currentUser); }
  document.getElementById('forgotSuccess').style.display = 'block';
}

function doChangePassword() {
  if (!currentUser) return;
  const curr = document.getElementById('cpCurrent').value;
  const newp = document.getElementById('cpNew').value;
  hideMsg('cpError'); hideMsg('cpSuccess');
  if (curr !== currentUser.password) return showErr('cpError', 'Current password is incorrect.');
  if (newp.length < 6) return showErr('cpError', 'New password must be at least 6 characters.');
  const users = getUsers();
  users[currentUser.email].password = newp;
  saveUsers(users);
  currentUser.password = newp;
  saveCurrentUser(currentUser);
  document.getElementById('cpSuccess').style.display = 'block';
}

function doEditProfile() {
  if (!currentUser) return;
  const name = document.getElementById('epName').value.trim();
  const address = document.getElementById('epAddress').value.trim();
  const pic = document.getElementById('epPic').value.trim();
  hideMsg('epError');
  if (!name) return showErr('epError', 'Name cannot be empty.');
  const users = getUsers();
  users[currentUser.email].name = name;
  users[currentUser.email].address = address;
  users[currentUser.email].pic = pic;
  saveUsers(users);
  currentUser = users[currentUser.email];
  saveCurrentUser(currentUser);
  closeModal('editProfileModal');
  if (showingProfile) showProfile();
}

