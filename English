// ===================================================
//  QUIZ — ENHANCED BILINGUAL SYSTEM
// ===================================================
let quizData = [];
let quizAnswers = [];
let quizCurrent = 0;

/**
 * Build quiz questions — THREE question types mixed:
 * 1. eng2ben  : ইংরেজি বাক্য দেওয়া → সঠিক বাংলা অর্থ বেছে নাও (pattern meaning)
 * 2. ben2eng  : বাংলা অর্থ দেওয়া → সঠিক ইংরেজি বাক্য বেছে নাও
 * 3. pat2ben  : Pattern structure দেওয়া → সঠিক বাংলা অর্থ বেছে নাও
 *
 * Questions are shuffled so each quiz feels different.
 */
function buildQuizQuestions(patterns) {
  const questions = [];

  patterns.forEach((p, idx) => {
    // Pick a random example from this pattern's pool
    const correctExample = p.pool[Math.floor(Math.random() * p.pool.length)];

    // Collect wrong English examples from OTHER patterns
    const wrongEngPool = patterns
      .filter((_, i) => i !== idx)
      .flatMap(op => op.pool);
    const wrongEngOptions = shuffleArray(wrongEngPool).slice(0, 3);

    // Collect wrong Bengali meanings from OTHER patterns
    const wrongBenPool = patterns
      .filter((_, i) => i !== idx)
      .map(op => op.ben);
    const wrongBenOptions = shuffleArray(wrongBenPool).slice(0, 3);

    // ── TYPE 1: English sentence → Bengali meaning ──
    // Show an example sentence, pick the correct Bengali pattern meaning
    questions.push({
      type: 'eng2ben',
      question: `নিচের ইংরেজি বাক্যটি কোন বাংলা প্যাটার্নের অন্তর্গত?\n\n"${correctExample}"`,
      patternHint: `Pattern: ${p.pat}`,
      options: shuffleArray([p.ben, ...wrongBenOptions]),
      correct: p.ben
    });

    // ── TYPE 2: Bengali meaning → correct English sentence ──
    // Show Bengali pattern meaning, pick the matching English sentence
    questions.push({
      type: 'ben2eng',
      question: `নিচের বাংলা অর্থের সাথে মিলে যায় এমন সঠিক ইংরেজি বাক্যটি বেছে নিন:\n\n"${p.ben}"`,
      patternHint: `Pattern: ${p.pat}`,
      options: shuffleArray([correctExample, ...wrongEngOptions]),
      correct: correctExample
    });
  });

  // Shuffle all questions and pick 15 (or all if fewer)
  return shuffleArray(questions).slice(0, 15);
}

function launchQuiz() {
  if (!currentUser) { openModal('needLoginModal'); return; }
  const patterns = ALL_DATA[currentSection].levels[currentLevel];
  quizData = buildQuizQuestions(patterns);
  quizAnswers = new Array(quizData.length).fill(null);
  quizCurrent = 0;

  document.getElementById('quizTitle').textContent = `📝 Level ${currentLevel+1} Quiz`;
  openModal('quizModal');
  renderQuizQuestion();
}

function renderQuizQuestion() {
  const q = quizData[quizCurrent];
  const body = document.getElementById('quizBody');
  const pct = Math.round((quizCurrent / quizData.length) * 100);

  // Badge based on question type
  const badgeMap = {
    eng2ben: '<span class="quiz-type-badge badge-eng2ben">🇧🇩 সঠিক বাংলা অর্থ বেছে নিন</span>',
    ben2eng: '<span class="quiz-type-badge badge-ben2eng">🇬🇧 সঠিক ইংরেজি বাক্য বেছে নিন</span>',
    pat2ben: '<span class="quiz-type-badge badge-pat2eng">🎯 প্যাটার্নের অর্থ বেছে নিন</span>'
  };

  body.innerHTML = `
    <div class="progress-bar-wrap"><div class="progress-bar" style="width:${pct}%"></div></div>
    <div class="quiz-progress">প্রশ্ন ${quizCurrent+1} / ${quizData.length}</div>
    ${badgeMap[q.type] || ''}
    <div class="quiz-question">
      <div class="quiz-q-num">Q${quizCurrent+1}</div>
      ${q.question.replace(/\n/g, '<br>')}
      <div class="quiz-pattern-hint">${q.patternHint}</div>
    </div>
    <div class="quiz-options" id="quizOpts">
      ${q.options.map((opt, i) => {
        const isSelected = quizAnswers[quizCurrent] === opt;
        return `<button class="quiz-option ${isSelected ? 'selected' : ''}" onclick="selectAnswer(${i})">${opt}</button>`;
      }).join('')}
    </div>
    <div id="quizFeedback"></div>
    <div class="quiz-nav" style="margin-top:15px;">
      ${quizCurrent > 0 ? `<button class="quiz-nav-btn" onclick="quizPrev()">← আগে</button>` : ''}
      ${quizCurrent < quizData.length - 1
        ? `<button class="quiz-nav-btn" onclick="quizNext()">পরে →</button>`
        : `<button class="quiz-nav-btn" style="background:var(--green);color:#000;border-color:var(--green);" onclick="submitQuiz()">জমা দিন ✓</button>`
      }
    </div>`;
}

function selectAnswer(idx) {
  const q = quizData[quizCurrent];
  const chosen = q.options[idx];
  quizAnswers[quizCurrent] = chosen;

  // Highlight selection
  document.querySelectorAll('.quiz-option').forEach((btn, i) => {
    btn.classList.remove('selected', 'correct', 'wrong');
    btn.disabled = true; // Lock after selection
    if (i === idx) {
      btn.classList.add(chosen === q.correct ? 'correct' : 'wrong');
    } else if (q.options[i] === q.correct) {
      btn.classList.add('correct'); // Always show correct answer
    }
  });

  // Show instant feedback
  const fb = document.getElementById('quizFeedback');
  if (chosen === q.correct) {
    fb.innerHTML = `<div class="quiz-feedback correct-fb">✅ সঠিক উত্তর! দারুণ হয়েছে!</div>`;
  } else {
    fb.innerHTML = `<div class="quiz-feedback wrong-fb">❌ ভুল হয়েছে। সঠিক উত্তর সবুজ রঙে দেখানো হয়েছে।</div>`;
  }
}

function quizNext() {
  if (quizAnswers[quizCurrent] === null) { alert('একটি উত্তর বেছে নিন।'); return; }
  quizCurrent++;
  renderQuizQuestion();
}

function quizPrev() {
  quizCurrent--;
  renderQuizQuestion();
}

function submitQuiz() {
  if (quizAnswers[quizCurrent] === null) { alert('একটি উত্তর বেছে নিন।'); return; }

  let correctCount = 0;
  quizData.forEach((q, i) => { if (quizAnswers[i] === q.correct) correctCount++; });
  const score = Math.round((correctCount / quizData.length) * 100);
  const passed = score >= 80;

  // Save history
  const history = getHistory(currentUser.email);
  history.unshift({
    date: new Date().toLocaleDateString(),
    section: ALL_DATA[currentSection].name,
    level: currentLevel + 1,
    score, passed
  });
  saveHistory(currentUser.email, history.slice(0, 50));

  // Unlock next level if passed
  if (passed) {
    const unlocked = getUnlocked(currentUser.email);
    if (!unlocked[currentSection]) unlocked[currentSection] = [0];
    const nextLevel = currentLevel + 1;
    if (nextLevel < 5 && !unlocked[currentSection].includes(nextLevel)) {
      unlocked[currentSection].push(nextLevel);
    }
    saveUnlocked(currentUser.email, unlocked);
  }

  // Build review items (show wrong answers)
  const wrongItems = quizData
    .map((q, i) => ({ q, answered: quizAnswers[i], ok: quizAnswers[i] === q.correct }))
    .filter(item => !item.ok)
    .slice(0, 5);

  const body = document.getElementById('quizBody');
  body.innerHTML = `
    <div class="quiz-result">
      <div class="quiz-score">${score}%</div>
      <div class="quiz-result-msg">${passed ? '🎉 অভিনন্দন! আপনি পাস করেছেন!' : '😔 পাস করতে ৮০% লাগবে। আরেকবার চেষ্টা করুন।'}</div>

      <div class="quiz-stat-row">
        <div class="quiz-stat-box correct-box">
          <div class="quiz-stat-num">${correctCount}</div>
          <div class="quiz-stat-label">✅ সঠিক</div>
        </div>
        <div class="quiz-stat-box wrong-box">
          <div class="quiz-stat-num">${quizData.length - correctCount}</div>
          <div class="quiz-stat-label">❌ ভুল</div>
        </div>
      </div>

      <div class="quiz-result-sub">
        মোট ${quizData.length}টি প্রশ্নের মধ্যে ${correctCount}টি সঠিক
        ${passed && currentLevel < 4 ? ` — Level ${currentLevel+2} এখন আনলক হয়েছে! 🔓` : ''}
      </div>

      ${wrongItems.length > 0 ? `
        <div class="review-section">
          <div class="review-title">📖 ভুল উত্তরের পর্যালোচনা</div>
          ${wrongItems.map(item => `
            <div class="review-item bad">
              <div class="ri-q">${item.q.question.replace(/\n/g,'').substring(0,80)}...</div>
              <div class="ri-correct">✅ সঠিক: ${item.q.correct.substring(0,70)}</div>
              <div class="ri-wrong">❌ আপনার: ${(item.answered||'উত্তর দেননি').substring(0,70)}</div>
            </div>`).join('')}
        </div>` : `<div style="color:var(--green);font-weight:700;margin:10px 0;">🌟 সব উত্তর সঠিক! অসাধারণ!</div>`
      }

      <div style="display:flex;gap:10px;justify-content:center;margin-top:20px;flex-wrap:wrap;">
        <button class="quiz-nav-btn" onclick="closeModal('quizModal');renderAll();">
          ${passed ? '✅ পরবর্তী লেভেলে যান' : '← ফিরে যান'}
        </button>
        ${!passed ? `<button class="quiz-nav-btn" style="border-color:var(--pink);color:var(--pink);" onclick="launchQuiz()">🔄 আবার চেষ্টা করুন</button>` : ''}
      </div>
    </div>`;
}

// ===================================================
//  PROFILE
// ===================================================
let showingProfile = false;

function showProfile() {
  if (!currentUser) { openModal('loginModal'); return; }
  showingProfile = true;
  const history = getHistory(currentUser.email);
  const unlocked = getUnlocked(currentUser.email);
  let totalUnlocked = 0;
  Object.values(unlocked).forEach(arr => totalUnlocked += arr.length);

  const container = document.getElementById('mainContainer');
  container.innerHTML = `
    <div class="profile-box">
      <div class="profile-avatar-wrap">
        ${currentUser.pic
          ? `<img class="profile-avatar" src="${currentUser.pic}" onerror="this.style.display='none'" alt="Profile">`
          : `<div class="profile-avatar-placeholder">👤</div>`}
        <div class="profile-name-display">${currentUser.name}</div>
        <div class="profile-email-display">${currentUser.email}</div>
        ${currentUser.address ? `<div style="color:#888;font-size:0.8rem;margin-top:4px;">📍 ${currentUser.address}</div>` : ''}
      </div>

      <div class="profile-section-title">📊 Progress</div>
      <div style="display:flex;gap:15px;flex-wrap:wrap;">
        <div style="flex:1;min-width:120px;background:rgba(0,240,255,0.07);border:1px solid rgba(0,240,255,0.2);border-radius:12px;padding:15px;text-align:center;">
          <div style="font-size:2rem;font-weight:700;color:var(--aqua);">${totalUnlocked}</div>
          <div style="font-size:0.75rem;color:#888;">Levels Unlocked</div>
        </div>
        <div style="flex:1;min-width:120px;background:rgba(0,255,136,0.07);border:1px solid rgba(0,255,136,0.2);border-radius:12px;padding:15px;text-align:center;">
          <div style="font-size:2rem;font-weight:700;color:var(--green);">${history.filter(h=>h.passed).length}</div>
          <div style="font-size:0.75rem;color:#888;">Quizzes Passed</div>
        </div>
        <div style="flex:1;min-width:120px;background:rgba(255,207,84,0.07);border:1px solid rgba(255,207,84,0.2);border-radius:12px;padding:15px;text-align:center;">
          <div style="font-size:2rem;font-weight:700;color:var(--gold);">${history.length}</div>
          <div style="font-size:0.75rem;color:#888;">Total Attempts</div>
        </div>
      </div>

      <div class="profile-section-title">📋 Quiz History</div>
      ${history.length === 0
        ? `<p style="color:#666;font-size:0.85rem;">এখনো কোনো কুইজ দেননি।</p>`
        : history.slice(0, 10).map(h => `
          <div class="history-item">
            <div>
              <div style="font-weight:600;">${h.section} — Level ${h.level}</div>
              <div style="color:#666;font-size:0.75rem;">${h.date}</div>
            </div>
            <div class="history-score ${h.passed ? 'pass' : 'fail'}">${h.score}% ${h.passed ? '✓' : '✗'}</div>
          </div>`).join('')}

      <div class="profile-section-title">⚙️ Account Settings</div>
      <div class="profile-actions">
        <button class="profile-action-btn" onclick="openEditProfile()">✏️ Edit Profile</button>
        <button class="profile-action-btn" onclick="openModal('changePwModal')">🔄 Change Password</button>
        <button class="profile-action-btn" onclick="openModal('forgotModal')">🔑 Forgot Password</button>
        <button class="profile-action-btn danger" onclick="doLogout()">🚪 Logout</button>
      </div>
      <div style="margin-top:16px;text-align:center;">
        <button class="hdr-btn" onclick="showingProfile=false;renderAll();">← Back to Learning</button>
      </div>
    </div>`;
}

function openEditProfile() {
  document.getElementById('epName').value = currentUser.name || '';
  document.getElementById('epAddress').value = currentUser.address || '';
  document.getElementById('epPic').value = currentUser.pic || '';
  hideMsg('epError');
  openModal('editProfileModal');
}

// ===================================================
//  AUDIO
// ===================================================
function playAudio(text) {
  let existing = document.getElementById('googleTTSAudio');
  if (existing) { existing.pause(); existing.remove(); }
  const clean = encodeURIComponent(text.replace(/\[.*?\]/g, '').replace(/\+/g, '').trim());
  const audio = new Audio(`https://translate.google.com/translate_tts?ie=UTF-8&q=${clean}&tl=en-gb&client=tw-ob`);
  audio.id = 'googleTTSAudio';
  audio.playbackRate = 0.85;
  audio.play().catch(() => {
    const utter = new SpeechSynthesisUtterance(text);
    utter.lang = 'en-GB';
    window.speechSynthesis.speak(utter);
  });
}

// ===================================================
//  UTILITIES
// ===================================================
function shuffleArray(arr) {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

// ===================================================
//  INIT
// ===================================================
window.onload = () => {
  currentUser = getCurrentUser();
  updateHeader();
  renderAll();
};
</script>
