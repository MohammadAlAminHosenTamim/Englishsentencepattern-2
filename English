function generatePlaceholderLevels(secNum, startN) {
  const levels = [];
  for (let l = 0; l < 5; l++) {
    const items = [];
    for (let i = 0; i < 10; i++) {
      const n = startN + l * 10 + i;
      items.push({
        n, pat:`Pattern #${n} — Section ${secNum} Level ${l+1}`,
        ben:`এই প্যাটার্নটি সেকশন ${secNum}, লেভেল ${l+1} এ রয়েছে।`,
        pro:`প্যাটার্ন উচ্চারণ`,
        pool:[
          `Example sentence 1 for pattern ${n}.`,
          `Example sentence 2 for pattern ${n}.`,
          `Example sentence 3 for pattern ${n}.`,
          `Example sentence 4 for pattern ${n}.`,
          `Example sentence 5 for pattern ${n}.`
        ]
      });
    }
    levels.push(items);
  }
  return levels;
}

