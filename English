function getUsers() { try { return JSON.parse(localStorage.getItem('epUsers') || '{}'); } catch(e) { return {}; } }
function saveUsers(u) { localStorage.setItem('epUsers', JSON.stringify(u)); }
function getCurrentUser() { try { return JSON.parse(localStorage.getItem('epCurrentUser') || 'null'); } catch(e) { return null; } }
function saveCurrentUser(u) { localStorage.setItem('epCurrentUser', u ? JSON.stringify(u) : 'null'); }

function getUnlocked(email) {
  try {
    const data = JSON.parse(localStorage.getItem('epUnlocked') || '{}');
    return data[email] || { sec1: [0] };
  } catch(e) { return { sec1: [0] }; }
}
function saveUnlocked(email, obj) {
  const data = JSON.parse(localStorage.getItem('epUnlocked') || '{}');
  data[email] = obj;
  localStorage.setItem('epUnlocked', JSON.stringify(data));
}

function getHistory(email) {
  try { return JSON.parse(localStorage.getItem('epHistory_' + email) || '[]'); } catch(e) { return []; }
}
function saveHistory(email, arr) { localStorage.setItem('epHistory_' + email, JSON.stringify(arr)); }

function isUnlocked(secKey, levelIdx) {
  if (secKey === 'sec1' && levelIdx === 0) return true;
  if (!currentUser) return false;
  const u = getUnlocked(currentUser.email);
  return (u[secKey] || []).includes(levelIdx);
}

